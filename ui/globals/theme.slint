/// Theme global — color tokens for dark mode (default)
///
/// All hardcoded color values live here.
/// Components reference these color properties instead of hex literals.
export global Theme {
    /// Primary background color (light gray for panels)
    out property <color> bg-panel: #f0f0f0;

    /// Primary background color (dark gray for waveform area)
    out property <color> bg-waveform: #1a1a1a;

    /// Waveform accent color (bright cyan)
    out property <color> accent-waveform: #00d4ff;

    /// Text color (dark)
    out property <color> text-dark: #000000;

    /// Text color (light)
    out property <color> text-light: #ffffff;
}
